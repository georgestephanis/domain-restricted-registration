{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/wp-admin/options-general.php",
  "preferredVersions": {
    "php": "8.2",
    "wp": "latest"
  },
  "steps": [
    {
      "step": "login",
      "username": "admin"
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "git:directory",
        "url": "https://github.com/georgestephanis/domain-restricted-registration",
        "ref": "main",
        "refType": "branch"
      },
      "options": {
        "activate": true,
        "targetFolderName": "domain-restricted-registration"
      }
    }
  ]
}
