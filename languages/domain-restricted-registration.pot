#. Plugin Name of the plugin
#: domain-restricted-registration.php
msgid "Domain-Restricted Registration"
msgstr ""

#. Description of the plugin
#: domain-restricted-registration.php
msgid "Restricts user registration to a single email domain and requires email confirmation before login."
msgstr ""

#. Author of the plugin
#: domain-restricted-registration.php
msgid "George Stephanis"
msgstr ""

#: domain-restricted-registration.php:107
msgid "Invalid domain format. Enter a domain like \"example.com\" without the @ symbol."
