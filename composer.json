{
	"$schema": "https://getcomposer.org/schema.json",
	"name": "georgestephanis/domain-restricted-registration",
	"description": "Restricts WordPress user registration to a single email domain with email confirmation.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require-dev": {
		"squizlabs/php_codesniffer": "^3.11",
		"wp-coding-standards/wpcs": "^3.1",
		"phpcsstandards/phpcsutils": "^1.0",
		"phpcsstandards/phpcsextra": "^1.2"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"lint": "phpcs",
		"lint:php": "@lint",
		"lint-fix": "phpcbf",
		"make-pot": "wp i18n make-pot . languages/domain-restricted-registration.pot --domain=domain-restricted-registration --exclude=vendor,node_modules"
	}
}
